# Cortex Configuration
# Source: Merged from Open-WebUI and OpenClaw
# CORTEX MODIFICATION: Environment variables for Cortex unified system

###############################################################################
# CORTEX - CORE CONFIGURATION
###############################################################################

# Bind to Tailscale interface only (not 0.0.0.0)
TAILSCALE_ONLY=false

# Tailscale hostname for DNS naming
TAILSCALE_HOSTNAME=cortex

###############################################################################
# CORTEX - MODEL CONFIGURATION
###############################################################################

# Default model for Cortex agent (e.g., 'cortex:latest', 'mistral', 'llama2')
CORTEX_DEFAULT_MODEL=cortex:latest

# Path to custom fine-tuned model (optional)
CORTEX_CUSTOM_MODEL_PATH=

###############################################################################
# CORTEX - MEMORY CONFIGURATION
###############################################################################

# Path to MEMORY.md file (long-term persistent memory)
MEMORY_PATH=./memory/MEMORY.md

# Path to DREAMS.md file (dreaming cycle results)
DREAMS_PATH=./memory/DREAMS.md

# Enable dreaming system (memory consolidation)
DREAMING_ENABLED=false

# Cron schedule for automatic dreaming (e.g., "0 3 * * *" = 3 AM daily)
DREAMING_SCHEDULE=0 3 * * *

###############################################################################
# CORTEX - DISCORD BOT CONFIGURATION
###############################################################################

# Enable Discord bot integration
DISCORD_BOT_ENABLED=false

# Discord bot token (get from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Comma-separated list of Discord channel IDs where bot can respond
DISCORD_ALLOWED_CHANNELS=

# Comma-separated list of Discord user IDs allowed to interact with bot
DISCORD_ALLOWED_USERS=

###############################################################################
# CORTEX - LOGGING CONFIGURATION
###############################################################################

# Log file path
LOG_FILE=./logs/cortex.log

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
CORTEX_LOG_LEVEL=INFO

###############################################################################
# OPEN-WEBUI - CORE CONFIGURATION (from open-webui)
###############################################################################

# Environment mode ('dev' enables swagger docs)
ENV=prod

# Instance ID for distributed deployments
INSTANCE_ID=

# OpenWebUI version (auto-detected)
VERSION=

# Automatic migrations
AUTOMATIC_MIGRATIONS=true

# Log format ('text' or 'json')
LOG_FORMAT=text

###############################################################################
# OPEN-WEBUI - DATABASE CONFIGURATION
###############################################################################

# SQLite database path
DATABASE_URL=sqlite:///data/webui.db

# For PostgreSQL: postgresql://user:password@localhost/webui_db
# For MySQL: mysql://user:password@localhost/webui_db

###############################################################################
# OPEN-WEBUI - WEBUI CONFIGURATION
###############################################################################

# Allow signup
ENABLE_SIGNUP=true

# Admin user email (create on startup)
WEBUI_ADMIN_EMAIL=

# Admin user password (create on startup)
WEBUI_ADMIN_PASSWORD=

# Admin user name
WEBUI_ADMIN_NAME=Admin

# Installation complete flag
INSTALLATION_COMPLETE=false

###############################################################################
# OPEN-WEBUI - OLLAMA CONFIGURATION
###############################################################################

# Enable Ollama API
ENABLE_OLLAMA_API=true

# Ollama base URL(s) - comma separated for multiple instances
OLLAMA_BASE_URLS=http://localhost:11434

# Ollama API key (if using auth)
OLLAMA_API_KEY=

###############################################################################
# OPEN-WEBUI - OPENAI CONFIGURATION
###############################################################################

# Enable OpenAI API
ENABLE_OPENAI_API=false

# OpenAI API base URLs - comma separated
OPENAI_API_BASE_URLS=https://api.openai.com/v1

# OpenAI API keys - comma separated (must match number of base URLs)
OPENAI_API_KEYS=

###############################################################################
# OPEN-WEBUI - AUTHENTICATION & SECURITY
###############################################################################

# JWT secret key for token signing (generate: openssl rand -hex 32)
SECRET_KEY=

# JWT algorithm
JWT_ALGORITHM=HS256

# JWT expiration seconds (default: 30 days)
JWT_EXPIRES_IN=2592000

# Enable OAuth2 support
ENABLE_OAUTH2=false

# OAuth2 providers configuration (JSON or provider-specific env vars)
# Supported: google, github, microsoft, etc.
OAUTH2_PROVIDERS=

# API key mode ('FLAT' = single key, 'RBAC' = role-based)
API_KEY_MODEL=FLAT

###############################################################################
# OPEN-WEBUI - LDAP CONFIGURATION
###############################################################################

# Enable LDAP authentication
ENABLE_LDAP=false

# LDAP server URL
LDAP_SERVER_LABEL=

# LDAP server address
LDAP_SERVER_HOST=

# LDAP server port
LDAP_SERVER_PORT=389

# LDAP bind DN
LDAP_BIND_DN=

# LDAP bind password
LDAP_BIND_PASSWORD=

# LDAP user search base
LDAP_USER_SEARCH_BASE=

# LDAP user search filter
LDAP_USER_SEARCH_FILTER=

###############################################################################
# OPEN-WEBUI - REDIS CONFIGURATION
###############################################################################

# Redis connection URL (optional for distributed caching)
REDIS_URL=

# Redis cluster mode
REDIS_CLUSTER=false

# Redis sentinel mode
REDIS_SENTINEL_HOSTS=

REDIS_SENTINEL_PORT=26379

###############################################################################
# OPEN-WEBUI - FILE STORAGE
###############################################################################

# Data directory for uploads and database
DATA_DIR=./data

# Cache directory
CACHE_DIR=./data/.cache

# Maximum file upload size (bytes, default 25MB)
MAX_UPLOAD_SIZE=26214400

###############################################################################
# OPEN-WEBUI - RAG (RETRIEVAL AUGMENTED GENERATION)
###############################################################################

# Enable RAG embeddings
ENABLE_RAG_WEBUI_MANAGEMENT=true

# Embedding model (e.g., 'nomic-embed-text', 'bge-m3')
RAG_EMBEDDING_MODEL=nomic-embed-text

# Embedding model format ('sentence-transformers' or 'ollama')
RAG_EMBEDDING_MODEL_FORMAT=sentence-transformers

# Reranking enabled
RAG_RERANKING_ENABLED=false

# Reranking model
RAG_RERANKING_MODEL=ms-marco-MiniLM-L-12-v2

# Query RAG on new chat
RAG_QUERY_ON_NEW_CHAT=false

###############################################################################
# OPEN-WEBUI - CODE EXECUTION
###############################################################################

# Enable code execution
ENABLE_CODE_EXECUTION=true

# Code execution engine ('docker' or 'pyodide')
CODE_EXECUTION_ENGINE=docker

# Jupyter server for code execution
CODE_EXECUTION_JUPYTER_URL=

# Code interpreter enabled
ENABLE_CODE_INTERPRETER=false

###############################################################################
# OPEN-WEBUI - ADMIN SETTINGS
###############################################################################

# Enable admin analytics
ENABLE_ADMIN_ANALYTICS=true

# SCIM 2.0 API support (user provisioning)
ENABLE_SCIM=false

# Audit logging level ('none', 'minimal', 'standard', 'full')
AUDIT_LOG_LEVEL=none

# Safe mode (disable all functions/tools)
SAFE_MODE=false

###############################################################################
# OPEN-WEBUI - TELEMETRY & TRACKING
###############################################################################

# Allow telemetry collection
TELEMETRY_ENABLED=true

# Anonymous telemetry
ANONYMOUS_TELEMETRY=true

# Sentry error tracking
SENTRY_DSN=

###############################################################################
# DOCKER / DEPLOYMENT
###############################################################################

# Docker build tag
DOCKER_TAG=latest

# Host port for frontend
HOST_PORT=8080

# Host port for backend API
BACKEND_PORT=8000

# Host port for Ollama
OLLAMA_PORT=11434
