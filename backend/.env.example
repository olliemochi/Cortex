# Example environment configuration for Cortex backend
# Copy this to .env and update values as needed

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://cortex:cortex@localhost:5432/cortex_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# ============================================================================
# Security
# ============================================================================
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# Discord Integration (Optional)
# ============================================================================
DISCORD_TOKEN=
DISCORD_LOG_CHANNEL_ID=
DISCORD_MAX_MESSAGE_LENGTH=2000

# ============================================================================
# Tailscale Integration (Optional)
# ============================================================================
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=
TAILSCALE_AUTH_EXPIRY_DAYS=90

# ============================================================================
# Agent Configuration
# ============================================================================
AGENT_MODEL=gpt-4
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=2000
AGENT_CONTEXT_LIMIT=10

# ============================================================================
# Memory Configuration
# ============================================================================
MEMORY_AUTO_SAVE=true
MEMORY_AUTO_SAVE_INTERVAL=300  # seconds
MEMORY_CONSOLIDATION_INTERVAL=86400  # 24 hours
MEMORY_MAX_ENTRIES=10000

# ============================================================================
# Dream Configuration
# ============================================================================
DREAM_CYCLE_ENABLED=true
DREAM_CYCLE_INTERVAL=86400  # 24 hours
DREAM_CYCLE_START_HOUR=2  # 2 AM
DREAM_MIN_MEMORY_ENTRIES=5

# ============================================================================
# Tool Configuration
# ============================================================================
TOOLS_ENABLED=true
TOOLS_TIMEOUT=30  # seconds
TOOLS_MAX_WORKERS=5

# ============================================================================
# Cache Configuration (Optional - Redis)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=false
CACHE_TTL=3600  # seconds

# ============================================================================
# Email Configuration (Optional)
# ============================================================================
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=support@aetherassembly.org

# ============================================================================
# Monitoring & Observability
# ============================================================================
SENTRY_DSN=
PROMETHEUS_ENABLED=false
JAEGER_ENABLED=false

# ============================================================================
# Features
# ============================================================================
FEATURE_STREAMING=true
FEATURE_MEMORY_SEARCH=true
FEATURE_DREAMING=true
FEATURE_TOOLS=true
FEATURE_DISCORD=true
FEATURE_TAILSCALE=true

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development
DEBUG=true
