# Example environment configuration for Cortex frontend
# Copy this to .env.local and update values as needed

# ============================================================================
# API Configuration
# ============================================================================
# Backend API base URL
VITE_API_URL=http://localhost:8000/api

# WebSocket URL for real-time features
VITE_WS_URL=ws://localhost:8000/ws

# ============================================================================
# Environment
# ============================================================================
# Set to 'development', 'staging', or 'production'
VITE_ENV=development

# ============================================================================
# Feature Flags
# ============================================================================
VITE_FEATURE_STREAMING=true
VITE_FEATURE_MEMORY=true
VITE_FEATURE_DREAMING=true
VITE_FEATURE_TOOLS=true
VITE_FEATURE_DISCORD=true
VITE_FEATURE_TAILSCALE=true

# ============================================================================
# Application Settings
# ============================================================================
VITE_APP_NAME=Cortex
VITE_APP_VERSION=1.0.0

# Chat settings
VITE_CHAT_MAX_MESSAGE_LENGTH=4000
VITE_CHAT_AUTO_SCROLL=true
VITE_CHAT_SHOW_TIMESTAMPS=true

# Memory settings
VITE_MEMORY_ITEMS_PER_PAGE=20
VITE_MEMORY_AUTO_SAVE=true

# ============================================================================
# Theming (Optional)
# ============================================================================
# Light, dark, or auto
VITE_THEME=auto

# ============================================================================
# Analytics (Optional)
# ============================================================================
VITE_ANALYTICS_ENABLED=false
VITE_ANALYTICS_ID=

# ============================================================================
# Error Reporting (Optional)
# ============================================================================
VITE_ERROR_REPORTING=false
VITE_ERROR_REPORTING_DSN=

# ============================================================================
# Performance
# ============================================================================
# Enable debug info in console
VITE_DEBUG=true

# Enable performance monitoring
VITE_PERFORMANCE_MONITORING=false
