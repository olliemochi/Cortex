#!/usr/bin/env bash

################################################################################
# Cortex Desktop Application Launcher
# 
# Organization: AetherAssembly
# License: MIT
# 
# This script launches Cortex as a desktop application with proper
# process management, browser integration, and cleanup.
#
################################################################################

set -e

# Configuration
CORTEX_HOME="${CORTEX_HOME:-$HOME/.local/share/cortex}"
CORTEX_DATA="${CORTEX_DATA:-$CORTEX_HOME/data}"
CORTEX_LOGS="${CORTEX_LOGS:-$CORTEX_HOME/logs}"
VENV_PATH="${CORTEX_HOME}/venv"
CORTEX_INSTALL_PATH="/opt/cortex"
CORTEX_PORT=8000
FRONTEND_PORT=5173
CORTEX_URL="http://localhost:${CORTEX_PORT}"
FRONTEND_URL="http://localhost:${FRONTEND_PORT}"

# PID files for process management
BACKEND_PID_FILE="/tmp/cortex-backend-$$.pid"
FRONTEND_PID_FILE="/tmp/cortex-frontend-$$.pid"
CLEANUP_MARKER="/tmp/cortex-running-$$"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Functions
log_info() {
    echo -e "${GREEN}[$(date +'%H:%M:%S')]${NC} $*"
}

log_error() {
    echo -e "${RED}[$(date +'%H:%M:%S')] ERROR:${NC} $*" >&2
}

log_warn() {
    echo -e "${YELLOW}[$(date +'%H:%M:%S')] WARNING:${NC} $*"
}

# Cleanup function
cleanup() {
    log_info "Shutting down Cortex..."
    
    # Kill backend
    if [ -f "$BACKEND_PID_FILE" ]; then
        BACKEND_PID=$(cat "$BACKEND_PID_FILE")
        if kill -0 "$BACKEND_PID" 2>/dev/null; then
            kill "$BACKEND_PID" 2>/dev/null || true
            sleep 1
            kill -9 "$BACKEND_PID" 2>/dev/null || true
        fi
        rm -f "$BACKEND_PID_FILE"
    fi
    
    # Kill frontend
    if [ -f "$FRONTEND_PID_FILE" ]; then
        FRONTEND_PID=$(cat "$FRONTEND_PID_FILE")
        if kill -0 "$FRONTEND_PID" 2>/dev/null; then
            kill "$FRONTEND_PID" 2>/dev/null || true
            sleep 1
            kill -9 "$FRONTEND_PID" 2>/dev/null || true
        fi
        rm -f "$FRONTEND_PID_FILE"
    fi
    
    rm -f "$CLEANUP_MARKER"
    log_info "Cortex shut down successfully"
    exit 0
}

trap cleanup EXIT INT TERM

# Check if Cortex is already running
if [ -f "$CLEANUP_MARKER" ]; then
    OLD_PID=$(cat "$CLEANUP_MARKER")
    if kill -0 "$OLD_PID" 2>/dev/null; then
        log_warn "Cortex is already running (PID: $OLD_PID)"
        if command -v xdg-open &> /dev/null; then
            xdg-open "$FRONTEND_URL" &
        elif command -v open &> /dev/null; then
            open "$FRONTEND_URL" &
        fi
        exit 0
    fi
fi

# Initialize directories
mkdir -p "$CORTEX_HOME" "$CORTEX_DATA" "$CORTEX_LOGS"

log_info "Cortex AI Agent Platform"
log_info "Organization: AetherAssembly"
log_info ""

# Check if installation exists
if [ ! -d "$CORTEX_INSTALL_PATH" ]; then
    log_error "Cortex is not installed at $CORTEX_INSTALL_PATH"
    log_info "Please run: sudo cortex-install"
    exit 1
fi

# Check/create virtual environment
if [ ! -d "$VENV_PATH" ]; then
    log_info "Creating virtual environment..."
    python3 -m venv "$VENV_PATH"
    source "$VENV_PATH/bin/activate"
    
    log_info "Installing dependencies..."
    cd "$CORTEX_INSTALL_PATH/backend"
    pip install --upgrade pip setuptools wheel > /dev/null 2>&1
    pip install -r requirements.txt > /dev/null 2>&1
    
    cd "$CORTEX_INSTALL_PATH/frontend"
    npm install > /dev/null 2>&1
else
    source "$VENV_PATH/bin/activate"
fi

# Create .env if needed
if [ ! -f "$CORTEX_DATA/.env" ]; then
    log_info "Creating environment configuration..."
    cat > "$CORTEX_DATA/.env" << 'EOF'
# Cortex Local Development Configuration
DATABASE_URL=postgresql://cortex:cortex@localhost:5432/cortex_dev
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
EOF
fi

# Mark as running
echo $$ > "$CLEANUP_MARKER"

# Start backend
log_info "Starting backend API (port $CORTEX_PORT)..."
cd "$CORTEX_INSTALL_PATH/backend"
nohup uvicorn main:app --host 0.0.0.0 --port $CORTEX_PORT \
    > "$CORTEX_LOGS/backend.log" 2>&1 &
BACKEND_PID=$!
echo $BACKEND_PID > "$BACKEND_PID_FILE"
log_info "Backend PID: $BACKEND_PID"

# Wait for backend to be ready
RETRIES=30
while [ $RETRIES -gt 0 ]; do
    if curl -s "$CORTEX_URL/health" > /dev/null 2>&1; then
        log_info "Backend is ready"
        break
    fi
    RETRIES=$((RETRIES - 1))
    sleep 0.5
done

if [ $RETRIES -eq 0 ]; then
    log_warn "Backend may not be ready (timeout)"
fi

# Start frontend
log_info "Starting frontend UI (port $FRONTEND_PORT)..."
cd "$CORTEX_INSTALL_PATH/frontend"
nohup npm run dev -- --host 0.0.0.0 --port $FRONTEND_PORT \
    > "$CORTEX_LOGS/frontend.log" 2>&1 &
FRONTEND_PID=$!
echo $FRONTEND_PID > "$FRONTEND_PID_FILE"
log_info "Frontend PID: $FRONTEND_PID"

# Wait a moment for services to fully start
sleep 2

# Open browser
log_info "Opening browser at $FRONTEND_URL..."
if command -v xdg-open &> /dev/null; then
    xdg-open "$FRONTEND_URL" > /dev/null 2>&1 &
elif command -v open &> /dev/null; then
    open "$FRONTEND_URL" &
elif command -v firefox &> /dev/null; then
    firefox "$FRONTEND_URL" > /dev/null 2>&1 &
elif command -v chromium &> /dev/null; then
    chromium "$FRONTEND_URL" > /dev/null 2>&1 &
else
    log_warn "Could not open browser - please visit $FRONTEND_URL manually"
fi

log_info ""
log_info "Cortex is running!"
log_info "  Frontend:    $FRONTEND_URL"
log_info "  API:         $CORTEX_URL"
log_info "  API Docs:    $CORTEX_URL/docs"
log_info "  Logs:        $CORTEX_LOGS"
log_info ""
log_info "Press Ctrl+C to shut down"
log_info ""

# Wait for processes
wait $BACKEND_PID $FRONTEND_PID 2>/dev/null || true
